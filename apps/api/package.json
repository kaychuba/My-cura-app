    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@my-cura/shared-types": "workspace:*",
    "@my-cura/shared-utils": "workspace:*",
    "@nestjs/bull": "^10.2.1",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.3",
