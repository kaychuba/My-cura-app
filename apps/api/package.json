{
  "name": "@my-cura/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "migration:generate": "node scripts/typeorm.js migration:generate -d src/database/data-source.ts",
    "migration:run": "node scripts/typeorm.js migration:run -d src/database/data-source.ts",
    "migration:revert": "node scripts/typeorm.js migration:revert -d src/database/data-source.ts",
    "seed": "ts-node src/database/seeds/seed.ts"
  },
  "dependencies": {
