    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.0",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "fast-csv": "^5.0.1",
