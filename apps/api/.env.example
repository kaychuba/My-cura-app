# Copy to apps/api/.env and fill in. NOTHING in this file is a real secret.
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mycura
# Schema owner — used ONLY by migrations and seeds (CLI)
DB_USERNAME=mycura
DB_PASSWORD=<set-me>
# RLS-constrained app role (generate: openssl rand -hex 24)
DB_APP_USERNAME=mycura_app
DB_APP_PASSWORD=<set-me>
# Auth role: cross-tenant read of users/tenants only, no security bypass
DB_AUTH_USERNAME=mycura_auth
DB_AUTH_PASSWORD=<set-me>
# After setting these, apply to the database:
#   infrastructure/scripts/set-role-passwords.sh

# Tokens & encryption (generate each: openssl rand -hex 32)
JWT_SECRET=<set-me-64-hex>
JWT_REFRESH_SECRET=<set-me-64-hex>
ENCRYPTION_KEY=<set-me-64-hex>

REDIS_HOST=localhost
REDIS_PORT=6379
