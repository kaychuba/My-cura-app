# Copy to apps/api/.env and fill in. NOTHING in this file is a real secret.
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mycura
# Schema owner — used ONLY by migrations and seeds (CLI)
DB_USERNAME=mycura
DB_PASSWORD=<set-me>
# RLS-constrained app role (generate: openssl rand -hex 24)
DB_APP_USERNAME=mycura_app
DB_APP_PASSWORD=<set-me>
# Auth role: cross-tenant read of users/tenants only, no security bypass
DB_AUTH_USERNAME=mycura_auth
DB_AUTH_PASSWORD=<set-me>
# After setting these, apply to the database:
#   infrastructure/scripts/set-role-passwords.sh

# Tokens & encryption (generate each: openssl rand -hex 32)
JWT_SECRET=<set-me-64-hex>
JWT_REFRESH_SECRET=<set-me-64-hex>
ENCRYPTION_KEY=<set-me-64-hex>

REDIS_HOST=localhost
REDIS_PORT=6379

# --- Security hardening (added 2026-07) ---
# Version of ENCRYPTION_KEY (bump when rotating; see docs/DATA-PROTECTION.md §6)
ENCRYPTION_KEY_VERSION=1
# Retired keys still needed to read pre-rotation data: {"1":"<old 64-hex key>"}
ENCRYPTION_KEYS_RETIRED=
# Slack-compatible webhook for security & ops alerts (login-failure spikes,
# 5xx spikes, backup failures, replication problems)
ALERT_WEBHOOK_URL=
# Key for encrypting nightly database dumps (openssl rand -hex 32)
BACKUP_ENCRYPTION_KEY=
# ClamAV daemon for upload virus scanning (leave empty to skip in dev)
CLAMAV_HOST=
CLAMAV_PORT=3310
# Alert if the Postgres standby disconnects or lags (needs pg_monitor grant)
REPLICATION_MONITOR=false
